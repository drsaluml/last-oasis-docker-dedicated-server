#!/usr/bin/env python3
"""Steam A2S_INFO query — exits 0 if the server responds, 1 otherwise.

Used by the Docker HEALTHCHECK to detect a hung MistServer process that
still owns the port but no longer responds to game queries.
"""

import os
import socket
import sys

HOST = "127.0.0.1"
PORT = int(os.environ.get("SERVER_QUERY_PORT", "27015"))
TIMEOUT = 3

A2S_INFO = b"\xff\xff\xff\xffTSource Engine Query\x00"


def main() -> int:
    try:
        with socket.socket(socket.AF_INET, socket.SOCK_DGRAM) as s:
            s.settimeout(TIMEOUT)
            s.sendto(A2S_INFO, (HOST, PORT))
            data, _ = s.recvfrom(1400)
        return 0 if data and data[:4] == b"\xff\xff\xff\xff" else 1
    except Exception:
        return 1


if __name__ == "__main__":
    sys.exit(main())
