# Per-server secret template.
#
#   1. cp secret.yaml.example secret-last-oasis-1.yaml
#   2. Replace every <REPLACE_*> placeholder.
#   3. kubectl apply -f secret-last-oasis-1.yaml
#
# Do NOT commit the filled-in copy — keep it in a private secrets store.
# For multiple servers, change every "last-oasis-1" suffix to match the
# server you're deploying (last-oasis-2, last-oasis-3, ...).

apiVersion: v1
kind: Secret
metadata:
  name: last-oasis-1-secret
  namespace: last-oasis
type: Opaque
stringData:
  # ─── Required: from https://myrealm.lastoasis.gg/Settings ───────────
  SERVER_CUSTOMER_KEY: "<REPLACE_CUSTOMER_KEY>"
  SERVER_PROVIDER_KEY: "<REPLACE_PROVIDER_KEY>"

  # ─── Required: server identity ──────────────────────────────────────
  SERVER_IP_ADDRESS:   "<REPLACE_PUBLIC_IP_OF_NODE>"
  SERVER_IDENTIFIER:   "last-oasis-1"

  # ─── Required: ports (must be unique per realm + IP) ────────────────
  SERVER_PORT:         "62001"
  SERVER_QUERY_PORT:   "27015"

  # ─── Optional ───────────────────────────────────────────────────────
  SERVER_SLOTS:        "25"

  # STEAM_USER defaults to "anonymous". Override only for a personal
  # Steam account.
  # STEAM_USER:        "<your-steam-username>"
