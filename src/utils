#!/usr/bin/env bash

login(){
  run "$STEAM_CMD_BINARY +login $STEAM_USER +quit"
}

# Download and setup Last Oasis
#
# Retries on transient steamcmd "Missing configuration" failures, which
# happen when Steam's CMS hasn't propagated the anonymous license cache
# yet. Tunable via DOWNLOAD_MAX_ATTEMPTS (default: 5).
download(){
  info "Download Last Oasis"

  local attempt=0
  local max="${DOWNLOAD_MAX_ATTEMPTS:-5}"

  while [ "$attempt" -lt "$max" ]; do
    attempt=$((attempt + 1))
    info "Download attempt $attempt/$max"

    if run "$STEAM_CMD_BINARY \
      +force_install_dir $INSTALL_DIR \
      +login $STEAM_USER \
      +app_license_request $STEAM_APP_ID \
      +app_update $STEAM_APP_ID validate \
      +quit"; then
      return 0
    fi

    if [ "$attempt" -lt "$max" ]; then
      local backoff=$((attempt * 5))
      info "steamcmd failed; retrying in ${backoff}s..."
      sleep "$backoff"
    fi
  done

  echo "[ERROR] download failed after $max attempts"
  return 1
}

# Provide correct steam app id to use for linux
provide_linux_app_id(){
  info "Provide linux app id"

  run "echo $STEAM_LINUX_APP_ID > ${SERVER_BINARY_PATH}steam_appid.txt"
}

# UE4 dedicated servers built with the Steam SDK dlopen
# steamclient.so from $HOME/.steam/sdk64 (and sdk32). steamcmd drops
# the .so under $HOME/.steam/steamcmd/linuxNN/, so we create the
# symlinks the engine expects. Idempotent — safe to run on every start.
ensure_steamclient_link(){
  for arch in 32 64; do
    local link="$HOME/.steam/sdk${arch}/steamclient.so"
    local target="$HOME/.steam/steamcmd/linux${arch}/steamclient.so"
    if [ ! -e "$target" ]; then
      continue
    fi
    if [ -L "$link" ] && [ "$(readlink "$link")" = "$target" ]; then
      continue
    fi
    mkdir -p "$(dirname "$link")"
    ln -sfT "$target" "$link"
    echo "[LINK] $link -> $target"
  done
}

# Start a single server
start_server(){
  if [ -n "$SERVER_SLOTS" ] && [ "$SERVER_SLOTS" -gt 100 ] 2>/dev/null; then
    echo "[WARNING] SERVER_SLOTS=$SERVER_SLOTS exceeds the recommended max of 100"
  fi

  ensure_steamclient_link

  run "${SERVER_BINARY_PATH}MistServer-Linux-Shipping \
    $SERVER_OPTIONS \
    -identifier=$SERVER_IDENTIFIER \
    -port=$SERVER_PORT \
    -QueryPort=$SERVER_QUERY_PORT \
    -CustomerKey=$SERVER_CUSTOMER_KEY \
    -ProviderKey=$SERVER_PROVIDER_KEY \
    -slots=$SERVER_SLOTS \
    -OverrideConnectionAddress=$SERVER_IP_ADDRESS"
}

# Backup save data to a tarball
backup_saves(){
  info "Backup save data"

  BACKUP_DIR="${BACKUP_DIR:-$INSTALL_DIR/backups}"
  SAVED_DIR="$INSTALL_DIR/Mist/Saved"
  TIMESTAMP=$(date +%Y%m%d-%H%M%S)
  BACKUP_FILE="$BACKUP_DIR/last-oasis-saves-$TIMESTAMP.tar.gz"

  if [ ! -d "$SAVED_DIR" ]; then
    echo "[ERROR] Save directory not found: $SAVED_DIR"
    exit 1
  fi

  run "mkdir -p '$BACKUP_DIR'"
  run "tar -czf '$BACKUP_FILE' -C '$INSTALL_DIR/Mist' Saved"
  echo "[BACKUP] Saved to $BACKUP_FILE"
}

# Show formatted info
info(){
  echo "[$INFO] $1"
}

# Print and run given command
run(){
  echo "> $1"
  eval $1
}
